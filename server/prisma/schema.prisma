generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// สถานะคำสั่งซื้อตามเอกสาร Logistics (ecom1.order.orderStatus)
enum OrderStatus {
  PENDING
  VERIFYING
  PENDING_CONFIRMATION
  PROCESSING
  READY_FOR_PICKUP
  RIDER_ASSIGNED
  PICKED_UP
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  COMPLETED
  CANCELLED
  CANCELLATION_REQUESTED
  REFUND_REQUESTED
  REFUNDED
}

// สถานะการจัดส่ง (ecom1.shipment.status)
enum ShipmentStatus {
  WAITING_PICKUP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?
  name      String?
  picture   String?
  role      String   @default("user")
  enabled   Boolean  @default(true)
  address   String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  carts              Cart[]
  orders             Order[]
  stores             Store[]
  reviews            Review[]
  coupons            Coupon[]
  shipmentsAsCourier Shipment[]
  wallet             Wallet?
  orderReturns       OrderReturn[]
  returnPickupsAsCourier ReturnPickup[]

  @@map("user")
}

// กระเป๋าตังลูกค้า — ยอดคงเหลือและประวัติ (คืนเงินเมื่อยกเลิกออเดอร์ที่ชำระ QR แล้ว)
model Wallet {
  id            Int                   @id @default(autoincrement())
  userId        Int                   @unique
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance       Decimal               @db.Decimal(10, 2) @default(0)
  status       String                 @default("ACTIVE") // ACTIVE | FROZEN
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  transactions  WalletTransaction[]

  @@map("wallet")
}

model WalletTransaction {
  id          Int      @id @default(autoincrement())
  walletId    Int
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(10, 2)
  type        String   // DEPOSIT | WITHDRAW | PAYMENT | REFUND
  referenceId String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([walletId])
  @@map("wallet_transaction")
}

model Product {
  id                Int              @id @default(autoincrement())
  // sku อยู่ใน product_variant; ถ้า product.sku มีใน DB ให้เพิ่มกลับ: sku String? @unique
  title             String
  description       String?  @db.Text
  price             Float
  discountPrice     Float? // ราคาลดพิเศษ
  discountStartDate DateTime? // วันที่เริ่มลดราคา
  discountEndDate   DateTime? // วันที่สิ้นสุดลดราคา
  sold              Int              @default(0)
  quantity          Int
  createdAt         DateTime         @default(now()) @map("createdAt")
  updatedAt         DateTime         @updatedAt @map("updatedAt")
  categoryId        Int
  images            Image[]
  category          Category         @relation(fields: [categoryId], references: [id])
  cartItems         ProductOnCart[]
  orderItem         ProductOnOrder[]
  storeId           Int?
  store             Store?           @relation(fields: [storeId], references: [id])
  reviews           Review[]
  variants          ProductVariant[] // ตัวเลือกสี/ไซส์ จากตาราง product_variant (ecom1)

  @@index([categoryId], map: "Product_categoryId_fkey")
  @@index([storeId], map: "Product_storeId_fkey")
  @@map("product")
}

// ตาราง product_variant ใน DB (ecom1.sql) - เก็บตัวเลือกสี/ไซส์ และ SKU ต่อ variant
model ProductVariant {
  id         Int      @id @default(autoincrement())
  productId  Int
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  price      Decimal? @db.Decimal(10, 2)
  stock      Int
  imageIndex Int?
  attributes Json?    // เช่น {"สี":"ดำ","ไซส์":"L"}
  name       String   // เช่น "สีดำ / ไซส์L"
  sku        String?

  @@index([productId])
  @@map("product_variant")
}

model Store {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  logo        String?
  idCard      String?
  address     String?
  status      String    @default("pending")
  ownerId     Int
  owner       User      @relation(fields: [ownerId], references: [id])
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  reviews     Review[]
  wallet      StoreWallet?
  returnPickups ReturnPickup[]

  @@index([ownerId], map: "Store_ownerId_fkey")
  @@map("store")
}

// กระเป๋าตังของร้านค้า — ยอดคงเหลือและประวัติการเคลื่อนไหว
model StoreWallet {
  id            Int                      @id @default(autoincrement())
  storeId       Int                      @unique
  store         Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  balance       Decimal                  @db.Decimal(10, 2) @default(0)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  transactions  StoreWalletTransaction[]

  @@map("store_wallet")
}

model StoreWalletTransaction {
  id          Int           @id @default(autoincrement())
  walletId    Int
  wallet      StoreWallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(10, 2)
  type        String        // SALE_REVENUE | WITHDRAWAL | ADJUSTMENT
  referenceId String?       // orderId หรือ id อ้างอิง
  description String?
  createdAt   DateTime      @default(now())

  @@index([walletId])
  @@map("store_wallet_transaction")
}

model Order {
  id                Int              @id @default(autoincrement())
  cartTotal         Float
  discountAmount    Float            @default(0)
  discountCode      String?
  oderStatus        String           @default("Not Process") // legacy
  orderStatus       OrderStatus      @default(PENDING) @map("orderStatus") // Logistics flow
  shippingAddress   String?
  shippingPhone     String?
  trackingNumber    String?          // เลขพัสดุ (กรณีร้านส่งเอง)
  logisticsProvider String?          // บริษัทขนส่ง (provider)
  refundStatus      String?          @default("NONE")   // NONE | PENDING | REQUESTED | WAITING_FOR_PICKUP | RETURN_IN_TRANSIT | RETURN_DELIVERED | IN_DISPUTE | APPROVED | REJECTED
  refundReason      String?          @db.Text
  refundSlipUrl     String?
  refundDate        DateTime?
  receivedAt       DateTime?        // วันที่ลูกค้ารับของ (ใช้คำนวณรับประกัน 7 วัน)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  orderedById       Int
  orderedBy         User             @relation(fields: [orderedById], references: [id])
  products          ProductOnOrder[]
  payments          Payment[]
  couponId          Int?
  coupon            Coupon?          @relation(fields: [couponId], references: [id])
  notifications     Notification[]
  shipment          Shipment?
  trackingHistory   TrackingHistory[]
  orderReturns      OrderReturn[]

  @@index([orderedById], map: "Order_orderedById_fkey")
  @@index([couponId])
  @@map("order")
}

// การจัดส่ง 1:1 กับ Order (ecom1.shipment)
model Shipment {
  id            Int            @id @default(autoincrement())
  orderId       Int            @unique
  order         Order          @relation(fields: [orderId], references: [id])
  courierId     Int?
  courier       User?          @relation(fields: [courierId], references: [id])
  codAmount     Decimal        @default(0) @db.Decimal(10, 2)
  isCodPaid     Boolean       @default(false)
  latitude      Decimal?      @db.Decimal(10, 6)
  longitude     Decimal?     @db.Decimal(10, 6)
  pickupTime    DateTime?
  deliveredTime DateTime?
  status        ShipmentStatus @default(WAITING_PICKUP)
  proofImage    String?
  signatureImage String?
  failedReason  String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([courierId])
  @@map("shipment")
}

// ประวัติติดตามสถานะ (ecom1.tracking_history)
model TrackingHistory {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      String
  title       String
  description String?
  location    String?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@map("tracking_history")
}

model ProductOnOrder {
  id               Int      @id @default(autoincrement())
  productId        Int
  orderId          Int
  count            Int
  price            Float
  selectedVariants String?  @db.Text // JSON string of selected variants
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reviews          Review[]
  orderReturnItems OrderReturnItem[]

  @@index([orderId], map: "ProductOnOrder_orderId_fkey")
  @@index([productId], map: "ProductOnOrder_productId_fkey")
  @@map("productonorder")
}

// คำขอคืนสินค้า/คืนเงิน (ตาราง order_returns มีใน DB แล้ว)
model OrderReturn {
  id             Int       @id @default(autoincrement())
  orderId        Int
  userId         Int
  images         String?   @db.Text
  reason_code    String?
  reason_text    String?   @db.Text
  refund_amount  Decimal?  @db.Decimal(10, 2)
  admin_note     String?   @db.Text
  dispute_reason String?   @db.Text   // เหตุผลร้านค้าเมื่อแจ้งข้อพิพาท
  dispute_images String?   @db.Text   // JSON array ของ URL รูปหลักฐานข้อพิพาท
  resolved_at    DateTime?
  status         String    @default("REQUESTED") // REQUESTED | APPROVED | REJECTED
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items          OrderReturnItem[]
  returnPickups  ReturnPickup[]

  @@index([orderId])
  @@index([userId])
  @@map("order_returns")
}

// งานไรเดอร์ไปรับของคืน (Reverse Logistics) — ลูกค้า -> ร้านค้า
model ReturnPickup {
  id             Int          @id @default(autoincrement())
  orderReturnId  Int
  orderReturn    OrderReturn  @relation(fields: [orderReturnId], references: [id], onDelete: Cascade)
  pickupAddress  String       @db.Text
  pickupPhone    String?
  storeId        Int
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  courierId      Int?
  courier        User?        @relation(fields: [courierId], references: [id], onDelete: SetNull)
  status         String       @default("WAITING_PICKUP") // WAITING_PICKUP | PICKED_UP | DELIVERED
  proofImage     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([orderReturnId])
  @@index([storeId])
  @@index([courierId])
  @@index([status])
  @@map("return_pickup")
}

model OrderReturnItem {
  id            Int          @id @default(autoincrement())
  orderReturnId Int
  orderItemId   Int
  quantity      Int
  unitPrice     Decimal      @db.Decimal(10, 2)
  orderReturn   OrderReturn  @relation(fields: [orderReturnId], references: [id], onDelete: Cascade)
  orderItem     ProductOnOrder @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderReturnId])
  @@index([orderItemId])
  @@map("order_return_items")
}

model Category {
  id       Int      @id @default(autoincrement())
  name     String
  image    String?  // รูปภาพสำหรับหมวดหมู่
  // createdAt/updatedAt ถ้ามีใน DB ให้เพิ่มกลับ
  products Product[]

  @@map("category")
}

model Cart {
  id          Int             @id @default(autoincrement())
  cartTotal   Float
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  orderedById Int
  orderedBy   User            @relation(fields: [orderedById], references: [id])
  products    ProductOnCart[]

  @@index([orderedById], map: "Cart_orderedById_fkey")
  @@map("cart")
}

model ProductOnCart {
  id               Int     @id @default(autoincrement())
  cartId           Int
  productId        Int
  count            Int
  price            Float
  selectedVariants String? @db.Text @map("selectedVariants") // บังคับใช้ camelCase ตรงกับ DB
  cart             Cart    @relation(fields: [cartId], references: [id])
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([cartId], map: "ProductOnCart_cartId_fkey")
  @@index([productId], map: "ProductOnCart_productId_fkey")
  @@map("productoncart")
}

// Customer review after purchase
model Review {
  id          Int      @id @default(autoincrement())
  rating      Int
  comment     String?
  images      String? // JSON string of image URLs (optional)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      Int
  productId   Int
  storeId     Int?
  orderItemId Int // reference ProductOnOrder to ensure purchased

  user      User           @relation(fields: [userId], references: [id])
  product   Product        @relation(fields: [productId], references: [id])
  store     Store?         @relation(fields: [storeId], references: [id])
  orderItem ProductOnOrder @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([productId], map: "Review_productId_idx")
  @@index([storeId], map: "Review_storeId_idx")
  @@index([userId], map: "Review_userId_idx")
  @@index([orderItemId], map: "Review_orderItemId_idx")
  @@map("review")
}

model Image {
  id         Int      @id @default(autoincrement())
  asset_id   String?  // บางแถวใน DB เป็น null ได้
  public_id  String?
  secure_url String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  productId  Int
  url        String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "Image_productId_fkey")
  @@map("image")
}

model Payment {
  id              Int       @id @default(autoincrement())
  amount          Float
  currency        String    @default("THB")
  method          String
  status          String    @default("pending")
  customerEmail   String?
  customerName    String?
  customerPhone   String?
  transactionId   String    @unique
  gatewayId       String?
  gatewayStatus   String?
  metadata        String? // JSON string
  qrCodeData      String? // ข้อมูล QR code สำหรับ payment
  paymentSlipUrl  String? // URL ของรูปสลีปที่อัพโหลด
  approvedBy      Int? // ID ของ admin ที่อนุมัติ
  approvedAt      DateTime? // วันที่อนุมัติ
  rejectedBy      Int? // ID ของ admin ที่ปฏิเสธ
  rejectedAt      DateTime? // วันที่ปฏิเสธ
  rejectionReason String? // เหตุผลที่ปฏิเสธ
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  orderId         Int
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  notifications   Notification[]

  @@index([orderId], map: "Payment_orderId_fkey")
  @@map("payment")
}

model Coupon {
  id              Int       @id @default(autoincrement())
  code            String    @unique
  discountAmount  Float // จำนวนส่วนลด (บาท)
  discountPercent Float? // เปอร์เซ็นต์ส่วนลด (ถ้ามี)
  minPurchase     Float? // ราคาขั้นต่ำในการใช้
  maxDiscount     Float? // ส่วนลดสูงสุด (บาท)
  isUsed          Boolean   @default(false)
  usedAt          DateTime?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  orders          Order[]

  @@index([userId])
  @@index([code])
  @@map("coupon")
}

// การแจ้งเตือน (สำหรับ payment status และ new products)
model Notification {
  id         Int       @id @default(autoincrement())
  type       String    // 'payment_pending', 'payment_approved', 'payment_rejected', 'new_product'
  title      String
  message    String    @db.Text
  isRead     Boolean   @default(false)
  userId     Int? // ถ้าเป็นแจ้งเตือนสำหรับ user เฉพาะ
  targetRole String? // 'admin', 'user', 'seller' - สำหรับแจ้งเตือนตาม role
  orderId    Int? // ถ้าเกี่ยวข้องกับ order
  paymentId  Int? // ถ้าเกี่ยวข้องกับ payment
  productId  Int? // ถ้าเกี่ยวข้องกับ product ใหม่
  storeId    Int? // ถ้าเกี่ยวข้องกับร้านค้า
  data       String?   @db.Text // JSON string สำหรับข้อมูลเพิ่มเติม
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  order   Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetRole])
  @@index([type])
  @@index([productId])
  @@index([storeId])
  @@map("notification")
}

model SiteSetting {
  id                    Int      @id @default(autoincrement())
  siteName              String   @default("Boxify")
  description           String?
  contactEmail          String?
  contactPhone          String?
  address               String?  @db.Text
  shippingFee           Float    @default(50)
  freeShippingThreshold Float    @default(1000)
  facebook              String?
  line                  String?
  maintenanceMode       Boolean  @default(false)
  updatedAt             DateTime @updatedAt

  @@map("sitesetting")
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String?
  image     String   @db.Text @map("imageUrl")
  link      String?
  position  String   @default("main") @map("position") // ถ้า DB ไม่มี position ให้ลองลบหรือใช้ @map("displayOrder")
  order     Int      @default(0)
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banner")
}
